<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.GA.SidebarController">

    <left>
        <VBox prefWidth="250.0" spacing="10.0" style="-fx-padding: 20px;" styleClass="header" stylesheets="@../Styles/Styles.css" BorderPane.alignment="CENTER">

            <ImageView fitHeight="113.0" fitWidth="107.0" mouseTransparent="true" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@../Images/LogoEventus-modified.png" />
                </image>
            </ImageView>

            <Label alignment="CENTER" text="Welcome to Eventus" textFill="#fffdfd" />

            <Label fx:id="userStatusLabel" alignment="CENTER" textFill="WHITE" />

            <!-- Menu container to manage dynamic elements -->
            <VBox fx:id="menuContainer" spacing="10.0" VBox.vgrow="ALWAYS">
                <Label onMouseClicked="#navigateToHome" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-cursor: hand;" text="Home" />


                <!-- Actuality Section -->
                <VBox spacing="5.0">
                    <Label fx:id="toggleActivityMenuLabel" onMouseClicked="#toggleActivityMenu" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-cursor: hand;" text="Actuality" />
                    <VBox fx:id="activityMenu" managed="false" spacing="5.0" visible="false">
                        <Button fx:id="getAllActivityButton" onAction="#navigateToGetAllActivity" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Available Activity" />
                        <Button fx:id="MyActivityButton" onAction="#navigateToMyActivity" style="-fx-background-color: transparent; -fx-text-fill: white;" text="My Actuality" />
                        <Button fx:id="addActivityButton" onAction="#navigateToaddActuality" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Add Actuality" />
                    </VBox>
                </VBox>

                <!-- Services Section -->
                <VBox spacing="5.0">
                    <Label fx:id="toggleHerbergementMenuLabel" onMouseClicked="#toggleHerbergementMenu" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-cursor: hand;" text="Services" />
                    <VBox fx:id="herbergementMenu" managed="false" spacing="5.0" visible="false">
                        <Button fx:id="viewHerbergementButton" onAction="#viewHerbergement" style="-fx-background-color: transparent; -fx-text-fill: white;" text="View Services" />
                        <Button fx:id="addHerbergementButton" onAction="#addHerbergement" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Add Services" />
                    </VBox>
                </VBox>
            </VBox>

            <!-- Logout Button (Fixed to Bottom) -->
            <Button fx:id="logoutButton" alignment="BOTTOM_CENTER" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Logout" VBox.vgrow="ALWAYS" />
        </VBox>
    </left>
</BorderPane>
