<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Pane?>

<AnchorPane prefHeight="727.0" prefWidth="1139.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Admin.GL.AfficherLocaux">
    <children>
        <!-- ScrollPane affichant la liste des services -->
        <ScrollPane fx:id="scrollPaneReservations" fitToWidth="true" layoutX="203.0" layoutY="88.0" prefHeight="634.0" prefWidth="980.0" style="-fx-background: transparent; -fx-border-color: transparent;" vbarPolicy="ALWAYS">
            <content>
                <GridPane fx:id="gridPaneLocaux" hgap="20" style="-fx-padding: 20;" vgap="20" />
            </content>
        </ScrollPane>
        <!-- Pane de navigation à gauche -->
        <Pane prefHeight="727.0" prefWidth="191.0" style="-fx-background-color: #ed4e00; -fx-background-radius: 0 30 0 30;">
            <children>
                <!-- Logo en haut -->
                <ImageView fitHeight="120.0" fitWidth="150.0" layoutX="25.0" layoutY="20.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../Images/Blanc_non_bg.png" />
                    </image>
                </ImageView>
                <!-- Boutons de navigation -->
                <Button layoutX="34.0" layoutY="180.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0" style="-fx-background-color: #1F2C50FF;" text="Home" textFill="WHITE" onAction="#goTohome" />
                <Button layoutX="33.0" layoutY="230.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0" style="-fx-background-color: #1F2C50FF;" text="Gérer service" textFill="WHITE" onAction="#gotocrudLocaux" />
                <Button layoutX="34.0" layoutY="280.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0" style="-fx-background-color: #1F2C50FF;" text="Consulter" textFill="WHITE" />
                <Button layoutX="34.0" layoutY="330.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0" style="-fx-background-color: #1F2C50FF;" text="Statistique" textFill="WHITE" />
                <Button layoutX="52.0" layoutY="396.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="96.0" style="-fx-background-color: #1F2C50FF;" text="Logout" textFill="WHITE" />
            </children>
        </Pane>
    </children>
</AnchorPane>
