<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.Admin.GP.GeneratePackController" style="-fx-padding: 20;">

    <Label text="Génération de Pack par IA" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TextArea fx:id="promptArea" promptText="Ex: Crée un pack mariage premium pour 200 personnes à Paris..."/>

    <Button text="Générer avec l'IA" onAction="#handleGenerate" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>

    <GridPane hgap="10" vgap="10" style="-fx-padding: 10; -fx-background-color: #f5f5f5;">
        <!-- Ligne 0 -->
        <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nomField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <!-- Ligne 1 -->
        <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="typeCombo" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <!-- Ligne 2 -->
        <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextArea fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <!-- Ligne 3 -->
        <Label text="Prix (€):" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="prixField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <!-- Ligne 4 -->
        <Label text="Invités max:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="invitesField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <!-- Ligne 5 -->
        <Label text="Budget prévu (€):" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="budgetField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <!-- Ligne 6 -->
        <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="dateField" promptText="AAAA-MM-JJ" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <!-- Ligne 7 -->
        <Label text="Lieu:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextField fx:id="lieuField" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
    </GridPane>

    <Button text="Sauvegarder le Pack" onAction="#handleSave" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
</VBox>