<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="330.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Admin.GP.PackCellController">

    <Pane layoutX="15.0" layoutY="20.0" prefHeight="360.0" prefWidth="300.0" style="-fx-background-radius: 25; -fx-background-color: linear-gradient(to bottom right, #f5f7fa 0%, #1e0fcb 100%);">
        <effect>
            <DropShadow color="rgba(0,0,0,0.15)" radius="15.0" spread="0.15" />
        </effect>

        <children>
            <Label fx:id="statusPack" layoutX="251.0" layoutY="19.0">
                <graphic>
                    <!-- Retirer le Pane inutile -->
                    <Circle fx:id="statusCircle" fill="TRANSPARENT" radius="10" strokeType="INSIDE" strokeWidth="2" />
                </graphic>
            </Label>

            <!-- Main Content -->
            <Label fx:id="NamePack" layoutX="25.0" layoutY="60.0" prefWidth="250.0" text="[Name]" textFill="#2c3e50" wrapText="true">
                <font>
                    <Font name="Playfair Display Bold" size="28.0" />
                </font>
            </Label>

            <!-- ... autres éléments ... -->

            <Label fx:id="DescPack" layoutX="25.0" layoutY="138.0" prefHeight="20.0" prefWidth="260.0" text="[Description]" textFill="#4a5568" wrapText="true">
                <font>
                    <Font name="Open Sans SemiBold" size="14.0" />
                </font>
            </Label>

            <!-- Ajout du TypePack -->
            <Label fx:id="TypePack" layoutX="14.0" layoutY="12.0" prefHeight="17.0" prefWidth="56.0" style="-fx-font-style: italic;" text="[Type]" textFill="#4a5568">
                <font>
                    <Font name="Open Sans SemiBold" size="12.0" />
                </font>
            </Label>
            <!-- Ajout du TypePack -->
            <Label fx:id="PrixPack" layoutX="160.0" layoutY="277.0" prefHeight="17.0" prefWidth="44.0" style="-fx-font-style: italic;" text="[Prix]" textFill="#4a5568">
                <font>
                    <Font name="Open Sans SemiBold" size="12.0" />
                </font>
            </Label>
            <!-- Ajout du TypePack -->
            <Label fx:id="NbrInvPack" layoutX="25.0" layoutY="236.0" prefHeight="17.0" prefWidth="103.0" style="-fx-font-style: italic;" text="[Nbr guests]" textFill="#4a5568">
                <font>
                    <Font name="Open Sans SemiBold" size="12.0" />
                </font>
            </Label><!-- Ajout du TypePack -->
            <Label fx:id="BudgetPack" layoutX="217.0" layoutY="257.0" prefHeight="17.0" prefWidth="87.0" style="-fx-font-style: italic;" text="[Budget prévu]" textFill="#4a5568">
                <font>
                    <Font name="Open Sans SemiBold" size="12.0" />
                </font>
            </Label>

            <!-- ... boutons ... -->

            <!-- Boutons stylisés avec CSS inline -->
            <Button fx:id="deleteButton" layoutX="25.0" layoutY="310.0" mnemonicParsing="false" prefHeight="40.0" prefWidth="120.0" style="-fx-background-radius: 15; -fx-cursor: hand; -fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2);" text="Delete" textFill="WHITE">
            </Button>
            <!-- Ajout du TypePack -->
            <Label fx:id="datePack" layoutX="25.0" layoutY="210.0" prefHeight="17.0" prefWidth="160.0" style="-fx-font-style: italic;" text="[Date]" textFill="#4a5568">
                <font>
                    <Font name="Open Sans SemiBold" size="12.0" />
                </font>
            </Label>
            <!-- Ajout du TypePack -->
            <Label fx:id="LieuPack" layoutX="25.0" layoutY="172.0" prefHeight="17.0" prefWidth="193.0" style="-fx-font-style: italic;" text="[lieux]" textFill="#4a5568">
                <font>
                    <Font name="Open Sans SemiBold" size="12.0" />
                </font>
            </Label>

            <Button layoutX="155.0" layoutY="310.0" mnemonicParsing="false" onAction="#handleUpdateClick" prefHeight="40.0" prefWidth="120.0" style="-fx-background-radius: 15; -fx-cursor: hand; -fx-background-color: linear-gradient(to bottom right, #48bb78, #38a169);" text="Update" textFill="WHITE">
            </Button>
         <Label layoutX="129.0" layoutY="258.0" text="Budget Prévu :" />
         <Label layoutX="129.0" layoutY="277.0" prefHeight="17.0" prefWidth="44.0" text="Prix : " />
        </children>
    </Pane>
</AnchorPane>
