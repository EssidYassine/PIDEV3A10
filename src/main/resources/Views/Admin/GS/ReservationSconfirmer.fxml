<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Pane?>

<AnchorPane prefHeight="700" prefWidth="1086"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.Admin.GS.ReservationSconfirmer"
            style="-fx-background-color: #ffffff;">

    <!-- Pane de navigation ajoutée à gauche -->
    <Pane prefHeight="711.0" prefWidth="191.0"
          style="-fx-background-color: #ed4e00; -fx-background-radius: 0 30 0 30;">
        <children>
            <!-- Logo en haut -->
            <ImageView fitHeight="120.0" fitWidth="150.0" layoutX="25.0" layoutY="20.0" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@../../../Images/Blanc_non_bg.png" />
                </image>
            </ImageView>
            <!-- Boutons de navigation -->
            <Button layoutX="34.0" layoutY="180.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0"
                    style="-fx-background-color: #1F2C50FF;" text="Home" textFill="WHITE" onAction="#gotohome" />
            <Button layoutX="33.0" layoutY="230.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0"
                    style="-fx-background-color: #1F2C50FF;" text="Gérer service" textFill="WHITE" />
            <Button layoutX="34.0" layoutY="280.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0"
                    style="-fx-background-color: #1F2C50FF;" text="Consulter" textFill="WHITE" onAction="#retourAfficherService" />
            <Button layoutX="34.0" layoutY="330.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="132.0"
                    style="-fx-background-color: #1F2C50FF;" text="Statistique" textFill="WHITE" />
            <Button layoutX="52.0" layoutY="396.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="96.0"
                    style="-fx-background-color: #1F2C50FF;" text="Logout" textFill="WHITE" />
        </children>
    </Pane>

    <!-- Contenu principal décalé à droite de la pane -->
    <Label layoutX="220.0" layoutY="20.0" text="🛠️ Services Confirmés"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;" />

    <ScrollPane layoutX="220.0" layoutY="70.0" prefHeight="550.0" prefWidth="800.0">
        <GridPane fx:id="gridPaneServicesConfirmes" hgap="20" vgap="20" style="-fx-padding: 20;">
            <!-- Les cartes de service confirmés seront ajoutées dynamiquement ici -->
        </GridPane>
    </ScrollPane>

    <Button layoutX="930.0" layoutY="650.0" text="⬅ Retour"
            style="-fx-background-color: #ff4d4d; -fx-text-fill: white; -fx-font-size: 18; -fx-background-radius: 10;"
            onAction="#retourAdminDashboard"/>

</AnchorPane>
