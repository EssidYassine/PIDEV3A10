<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/17.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.Client.GP.DownloadReservationController"
      style="-fx-background-color: #f0f4f8; -fx-padding: 40px;">

    <Text text="Réservation Confirmée !"
          style="-fx-fill: #2ecc71;">
        <Font size="24.0" />
    </Text>

    <Text text="Cliquez pour télécharger votre reçu PDF"
          style="-fx-fill: #7f8c8d;">
        <Font size="16.0" />
    </Text>

    <Button text="Télécharger le PDF"
            onAction="#handleDownload"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>

    <Button text="Retour à l'accueil"
            onAction="#backToHome"
            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 10 20;"/>

</VBox>