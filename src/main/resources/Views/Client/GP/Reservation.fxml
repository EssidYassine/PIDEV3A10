<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>

<AnchorPane prefHeight="700.0" prefWidth="1086" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Client.GP.ReservationController">

    <!-- Navigation Bar -->
    <HBox layoutX="9.0" layoutY="20.0" prefHeight="60.0" prefWidth="1061.0" spacing="30" style="-fx-alignment: center;">
        <children>
            <Label prefHeight="46.0" prefWidth="118.0" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1e0fc6;" text="Eventus" />
            <Label prefHeight="30.0" prefWidth="122.0" style="-fx-font-size: 20px; -fx-text-fill: #1e0fc6; -fx-font-weight: bold;" text="Réclamation" />
            <Button fx:id="btnRetour1" onAction="#retourHome1" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #1e0fc6; -fx-text-fill: white; -fx-font-size: 18; -fx-background-radius: 10;" text="Acceuil" />
        </children>
    </HBox>

    <!-- Formulaire de Réservation -->
    <VBox layoutX="50.0" layoutY="100.0" prefHeight="550.0" prefWidth="980.0" spacing="10" style="-fx-padding: 40; -fx-alignment: center; -fx-background-color: #FFFFFF; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <Label text="Formulaire de Réservation" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e0fc6;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Email Utilisateur:" style="-fx-min-width: 150;"/>
            <TextField fx:id="userEmailField" style="-fx-pref-width: 300;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Nombre d'Invités:" style="-fx-min-width: 150;"/>
            <TextField fx:id="nbreInvitesField" style="-fx-pref-width: 100;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Budget Alloué:" style="-fx-min-width: 150;"/>
            <TextField fx:id="budgetField" style="-fx-pref-width: 200;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Date Réservation:" style="-fx-min-width: 150;"/>
            <DatePicker fx:id="dateReservationField" style="-fx-pref-width: 200;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Lieu:" style="-fx-min-width: 150;"/>
            <ComboBox fx:id="lieuField" style="-fx-pref-width: 300;"/>
        </HBox>

        <VBox fx:id="servicesContainer" spacing="10" />

        <VBox spacing="5">
            <Label text="Commentaires:" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="commentaireField" prefHeight="80" style="-fx-border-color: #ccc;"/>
        </VBox>

        <Button text="Confirmer la Réservation" onAction="#handleAddReservation"  style="-fx-background-color: #1e0fc6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>
    </VBox>
</AnchorPane>