<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<!-- this file has the reservation  Form that displays when clicking on Reserver button  -->


<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Client.GL.ReservationController">
    <children>
        <VBox spacing="7" layoutX="20" layoutY="20" alignment="CENTER">
            <Label text="Réserver un Local" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <!-- Reservation Form -->
            <VBox fx:id="detailsContainer" spacing="10" style="-fx-padding: 20; -fx-alignment: center; -fx-background-color: #FFFFFF; -fx-border-radius: 10; -fx-background-radius: 10;">
                 <ImageView fx:id="imageViewLocal" fitHeight="100" fitWidth="190"/>
                <Label fx:id="labelAdresse" text="Adresse:" style="-fx-font-size: 16px; -fx-text-fill: #666666;"/>
                <Label fx:id="labelType" text="Type:" style="-fx-font-size: 16px; -fx-text-fill: #666666;"/>
                <Label fx:id="labelCapacite" text="Capacité:" style="-fx-font-size: 16px; -fx-text-fill: #666666;"/>
                <Label fx:id="labelTarifs" text="Tarifs:" style="-fx-font-size: 16px; -fx-text-fill: #666666;"/>
                <Label fx:id="equipementLabel" text="Équipement:" style="-fx-font-size: 16px; -fx-text-fill: #666666;"/>

                <HBox spacing="10">
                    <VBox>
                        <Label text="Date Début:"/>
                        <DatePicker fx:id="dateDebut"/>
                    </VBox>
                    <VBox>
                        <Label text="Date Fin:"/>
                        <DatePicker fx:id="dateFin"/>
                    </VBox>
                </HBox>

                <VBox>
                    <Label text="Statut:"/>
                    <ComboBox fx:id="statutCombo"/>
                </VBox>

                <Button text="Réserver" fx:id="reserveButton" onAction="#handleReserve" style="-fx-background-color: #1e0fc6; -fx-text-fill: white; -fx-background-radius: 10;"/>
                <Button text="Retour" fx:id="btnRetour" onAction="#retourListeLocaux" style="-fx-background-color: #ccc; -fx-text-fill: black; -fx-background-radius: 10;"/>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
