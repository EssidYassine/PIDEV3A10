<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="700.0" prefWidth="1086" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Client.GS.AcceuilService">

    <children>
        <!-- Navigation Bar -->
        <HBox layoutX="9.0" layoutY="20.0" prefHeight="60.0" prefWidth="1061.0" spacing="30" style="-fx-alignment: center;">
            <children>
                <Label onMouseClicked="#gotoHome" prefHeight="46.0" prefWidth="118.0" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1e0fc6;" text="Eventus" />
                <Label onMouseClicked="#gotoReserverMateriel" prefHeight="30.0" prefWidth="176.0" style="-fx-font-size: 20px; -fx-text-fill: #333;" text="Reserver Matériel" />
                <Label onMouseClicked="#gotoReserverStaff" prefHeight="30.0" prefWidth="142.0" style="-fx-font-size: 20px; -fx-text-fill: #333;" text="Reserver Staff" />
                <Label onMouseClicked="#gotoListeReservation" prefHeight="30.0" prefWidth="249.0" style="-fx-font-size: 20px; -fx-text-fill: #333;" text="Liste des réservations" />
                <Label prefHeight="30.0" prefWidth="122.0" style="-fx-font-size: 20px; -fx-text-fill: #1e0fc6; -fx-font-weight: bold;" text="Réclamation" />
            <Button fx:id="btnRetour1" onAction="#retourHome1" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #1e0fc6; -fx-text-fill: white; -fx-font-size: 18; -fx-background-radius: 10;" text="Acceuil" />
            </children>
        </HBox>
        <HBox layoutX="30.0" layoutY="70.0" spacing="0" style="-fx-alignment: center;">
            <!-- Champ de texte pour la recherche -->
            <TextField fx:id="searchBar" onKeyReleased="#filtrerServices" prefHeight="23.0" prefWidth="203.0" promptText="Rechercher un service..." style="-fx-background-color: white; -fx-background-radius: 30 0 0 30; -fx-font-size: 18px; -fx-padding: 10; -fx-border-color: transparent; -fx-border-radius: 30;" />

            <!-- Bouton de recherche -->
            <Button fx:id="searchButton" onAction="#filtrerServices" prefHeight="53.0" prefWidth="59.0" style="-fx-background-color: #ed4e00; -fx-background-radius: 0 30 30 0; -fx-text-fill: white; -fx-padding: 20; -fx-min-width: 50;">
                <graphic>
                    <Label prefHeight="19.0" prefWidth="18.0" style="-fx-font-size: 18px; -fx-text-fill: white;" text="🔍" />
                </graphic>
            </Button>

        </HBox>
        <!-- Liste des services dans un GridPane avec scrolling -->
        <ScrollPane fx:id="scrollPaneServices" fitToWidth="true" layoutX="31.0" layoutY="144.0" prefHeight="550.0" prefWidth="1016.0" style="-fx-background: transparent; -fx-border-color: transparent;" vbarPolicy="ALWAYS">
            <GridPane fx:id="gridPaneServices" hgap="20" style="-fx-padding: 20;" vgap="20">
                <!-- Les cartes des services seront ajoutées dynamiquement ici -->
            </GridPane>
        </ScrollPane>


    </children>
</AnchorPane>
